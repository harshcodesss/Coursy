PORT=8000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

ACCESS_TOKEN_SECRET=<generate-a-random-64-char-hex>
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=<generate-a-random-64-char-hex>
REFRESH_TOKEN_EXPIRY=10d

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP via Gmail App Password) ─────────────────────────────────────
# These MUST be set for OTP verification emails to work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

FROM_NAME=Coursy
FROM_EMAIL=your-email@gmail.com

# ─── OTP / Verification ──────────────────────────────────────────────────────
VERIFICATION_TOKEN_SECRET=<generate-a-random-32-char-hex>
VERIFICATION_TOKEN_EXPIRY=15m

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ─── API Keys ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
YOUTUBE_API_KEY=<your-youtube-api-key>
